{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "git push origin main",
            "if": "Bash(git commit*)",
            "statusMessage": "Pushing to GitHub..."
          }
        ]
      }
    ]
  }
}
